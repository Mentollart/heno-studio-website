---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = 'Heno Studio - architekt wnętrz Wrocław. Projektowanie wnętrz mieszkań i domów. Projekty koncepcyjne, kompleksowe i nadzór autorski. Bezpłatna wycena.',
  ogImage = '/og-image.jpg',
  canonicalUrl,
} = Astro.props;

const siteUrl = 'https://henostudio.pl';
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content="Heno Studio" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Global Styles -->
    <style is:global>
      @import '../styles/global.css';
    </style>

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Heno Studio",
      "alternateName": "Heno Studio - Architekt Wnętrz Wrocław",
      "url": "https://henostudio.pl",
      "logo": "https://henostudio.pl/logo.png",
      "image": "https://henostudio.pl/og-image.jpg",
      "description": "Studio architektury wnętrz we Wrocławiu. Projektowanie wnętrz mieszkań i domów - projekty koncepcyjne, kompleksowe i nadzór autorski.",
      "telephone": "+48607564257",
      "email": "kontakt@henostudio.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Wrocław",
        "addressCountry": "PL"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 51.1079,
        "longitude": 17.0385
      },
      "areaServed": [
        { "@type": "City", "name": "Wrocław" },
        { "@type": "State", "name": "Dolnośląskie" }
      ],
      "founder": {
        "@type": "Person",
        "name": "Patrycja Zarzycka-Paluch",
        "jobTitle": "Architekt wnętrz",
        "alumniOf": {
          "@type": "CollegeOrUniversity",
          "name": "Politechnika Wrocławska"
        }
      },
      "foundingDate": "2020",
      "priceRange": "od 150 zł/m²",
      "sameAs": [
        "https://facebook.com/heno.studio",
        "https://instagram.com/heno.studio"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Usługi projektowania wnętrz",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Projekt koncepcyjny", "description": "Wizualizacje 3D, moodboard, układ funkcjonalny" }, "price": "150", "priceCurrency": "PLN", "unitText": "za m²" },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Projekt kompleksowy", "description": "Pełna dokumentacja techniczna z listą zakupową" }, "price": "210", "priceCurrency": "PLN", "unitText": "za m²" },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Projekt kompleksowy z nadzorem", "description": "Kompleksowy projekt z nadzorem autorskim na budowie" }, "price": "320", "priceCurrency": "PLN", "unitText": "za m²" },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Konsultacje", "description": "Konsultacje na żywo lub online" }, "price": "500", "priceCurrency": "PLN" }
        ]
      }
    })} />

    <slot name="head" />
  </head>
  <body class={Astro.url.pathname.includes('kontakt') ? 'page-kontakt' : ''}>
    <a class="skip-link" href="#main-content">Przejdź do treści</a>

    <slot name="header">
      <Fragment set:html="" />
    </slot>

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer">
      <Fragment set:html="" />
    </slot>

    <!-- Toast element for email copy -->
    <div class="email-toast" id="email-toast"></div>

    <!-- Scroll Reveal Script -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>

    <!-- Mailto clipboard fallback -->
    <script>
      const toast = document.getElementById('email-toast');
      let toastTimeout: ReturnType<typeof setTimeout>;

      function showToast(email: string) {
        if (!toast) return;
        toast.textContent = `${email} — skopiowano do schowka!`;
        toast.classList.add('show');
        clearTimeout(toastTimeout);
        toastTimeout = setTimeout(() => toast.classList.remove('show'), 3500);
      }

      document.querySelectorAll('a[href^="mailto:"]').forEach((link) => {
        link.addEventListener('click', (e) => {
          const href = (link as HTMLAnchorElement).href;
          const email = href.replace('mailto:', '').split('?')[0];

          // Copy email to clipboard
          if (navigator.clipboard) {
            navigator.clipboard.writeText(email).then(() => {
              showToast(email);
            });
          }

          // Let the mailto: link fire naturally — if email client exists, it opens.
          // If not, user still has the email copied to clipboard via the toast.
        });
      });
    </script>
  </body>
</html>
