---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

import imgKoncepcyjny from '../assets/images/oferta-koncepcyjny.png';
import imgKompleksowy from '../assets/images/oferta-kompleksowy.png';
import imgNadzor from '../assets/images/oferta-nadzor.png';
import imgKonsultacje from '../assets/images/oferta-konsultacje.png';

const services = [
  {
    name: 'Projekt koncepcyjny',
    price: 'od 150 zł/m²',
    intro: 'Idealna opcja, jeśli chcesz mieć profesjonalną wizję swojego wnętrza i samodzielnie koordynować realizację. Otrzymujesz kompletny projekt wizualny — od moodboardu po wizualizacje 3D.',
    features: [
      'Inwentaryzacja',
      'Moodboard/styl',
      'Układ funkcjonalny',
      'Wizualizacje 3D',
      'Orientacyjna lista zakupowa — zdjęcia mebli i materiałów bez konkretnych linków',
    ],
    image: imgKoncepcyjny,
    alt: 'Salon z czerwoną sofą — projekt koncepcyjny Heno Studio',
  },
  {
    name: 'Projekt kompleksowy',
    price: 'od 210 zł/m²',
    intro: 'Pełna dokumentacja projektowa, dzięki której Twój wykonawca wie dokładnie, co i jak zrealizować. Zawiera rysunki techniczne, szczegółową listę zakupów z linkami oraz wizyty na budowie.',
    features: [
      'Inwentaryzacja',
      'Moodboard/styl',
      'Układ funkcjonalny',
      'Wizualizacje 3D',
      'Rysunki techniczne (zmiany w instalacjach elektrycznych i hydraulicznych)',
      'Szczegółowa lista zakupowa z linkami do konkretnych produktów',
      'Trzy wizyty na budowie',
    ],
    image: imgKompleksowy,
    alt: 'Sypialnia w kolorze różowym — projekt kompleksowy Heno Studio',
    popular: true,
  },
  {
    name: 'Projekt kompleksowy z nadzorem',
    price: 'od 320 zł/m²',
    intro: 'Kompleksowa opieka od pierwszego szkicu do klucza w drzwiach. Koordynujemy pracę zaufanej ekipy wykończeniowej, dostawy materiałów i wszelkie zmiany — Ty po prostu czekasz na gotowe wnętrze.',
    features: [
      'Inwentaryzacja',
      'Moodboard/styl',
      'Układ funkcjonalny',
      'Wizualizacje 3D',
      'Rysunki techniczne (zmiany w instalacjach elektrycznych i hydraulicznych)',
      'Szczegółowa lista zakupowa z linkami do konkretnych produktów',
      'Współpraca z zaufaną ekipą wykończeniową',
      'Wizyty na budowie według zapotrzebowania',
      'Koordynacja dostaw i zmian projektowych',
      'Stały kontakt z wykonawcami (telefoniczny lub mailowy)',
      'Pomoc w zamówieniach i zakupach',
    ],
    image: imgNadzor,
    alt: 'Nowoczesna sypialnia — projekt z nadzorem Heno Studio',
  },
  {
    name: 'Konsultacje na żywo lub online',
    price: 'od 500 zł',
    intro: 'Jednorazowa porada, gdy potrzebujesz profesjonalnej opinii na konkretny temat — dobór kolorów, układ mebli, wybór materiałów. Spotykamy się na żywo we Wrocławiu lub online.',
    features: [
      'Przygotowanie do omawianego zagadnienia na podstawie wcześniej przesłanych materiałów',
      'Rozmowa (na żywo we Wrocławiu lub online)',
      'Podsumowanie konsultacji w formie opisu, schematycznych rysunków lub moodboardu',
    ],
    image: imgKonsultacje,
    alt: 'Minimalistyczny korytarz — konsultacja projektowa Heno Studio',
  },
];
---

<BaseLayout
  title="Oferta | Architekt wnętrz Wrocław — Heno Studio"
  description="Poznaj ofertę Heno Studio: projekt koncepcyjny od 150 zł/m², kompleksowy od 210 zł/m², z nadzorem od 320 zł/m², konsultacje od 500 zł. Bezpłatna wycena."
>
  <Header slot="header" />

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Ścieżka nawigacji">
        <a href="/">Strona główna</a>
        <span>/</span>
        <span aria-current="page">Oferta</span>
      </nav>
      <h1 class="page-header__title">Oferta</h1>
      <p class="page-header__desc">
        Każdy projekt zaczynamy od bezpłatnej rozmowy. Dopasowujemy zakres usług do Twoich potrzeb, stylu życia i&nbsp;budżetu — od wizualizacji po kompleksowy nadzór nad realizacją.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="services-full section">
    <div class="container">
      {services.map((service, i) => (
        <article class:list={['service-card', 'reveal', { 'service-card--popular': service.popular }]} style={`transition-delay: ${i * 100}ms`}>
          <div class="service-card__image-wrap">
            <Image
              src={service.image}
              alt={service.alt}
              widths={[400, 600, 800]}
              sizes="(max-width: 768px) 100vw, 50vw"
              format="webp"
              quality={75}
              loading={i === 0 ? 'eager' : 'lazy'}
              class="service-card__image"
            />
          </div>
          <div class="service-card__content">
            {service.popular && <span class="service-card__badge">Najpopularniejszy</span>}
            <h2 class="service-card__name">{service.name}</h2>
            <p class="service-card__price">{service.price}</p>
            <p class="service-card__intro">{service.intro}</p>
            <h3 class="service-card__scope-title">Co otrzymujesz:</h3>
            <ul class="service-card__features">
              {service.features.map((f) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href={`mailto:kontakt@henostudio.com?subject=Zapytanie - ${service.name}`} class="btn btn--primary">
              Zapytaj o wycenę
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <ContactCTA variant="dark" />
  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header {
    padding-top: calc(var(--header-height) + var(--space-3xl));
    padding-bottom: var(--space-2xl);
    background: var(--color-bg-warm);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
  }

  .breadcrumb a:hover {
    color: var(--color-secondary-dark);
  }

  .page-header__title {
    margin-bottom: var(--space-md);
  }

  .page-header__desc {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    max-width: 640px;
  }

  .service-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .service-card:last-child {
    border-bottom: none;
  }

  .service-card:nth-child(even) {
    direction: ltr;
  }

  .service-card__image-wrap {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--color-bg-warm);
  }

  .service-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-card__badge {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--space-xs) var(--space-md);
    margin-bottom: var(--space-md);
  }

  .service-card__name {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-sm);
  }

  .service-card__price {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-secondary-dark);
    margin-bottom: var(--space-lg);
  }

  .service-card__intro {
    font-size: var(--text-base);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .service-card__scope-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .service-card__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .service-card__features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .service-card__features svg {
    color: var(--color-secondary);
    flex-shrink: 0;
    margin-top: 3px;
  }

  @media (min-width: 768px) {
    .service-card {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    .service-card:nth-child(even) .service-card__image-wrap {
      order: 2;
    }
  }
</style>
