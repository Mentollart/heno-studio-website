---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Map from '../components/Map.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Kontakt | Heno Studio — architekt wnętrz Wrocław"
  description="Skontaktuj się z Heno Studio: kontakt@henostudio.com, tel. +48 607 564 257. Bezpłatna wycena projektu wnętrza we Wrocławiu. Patrycja Zarzycka-Paluch."
>
  <Header slot="header" />

  <section class="kontakt-page">
    <div class="container">
      <div class="kontakt__grid">
        <div class="kontakt__main reveal">
          <p class="section-label">Kontakt</p>
          <h1 class="kontakt__title">
            Porozmawiajmy<br />o&nbsp;Twoim wnętrzu
          </h1>
          <p class="kontakt__desc">
            Napisz lub zadzwoń — opowiedz o swoim projekcie, a&nbsp;przygotuję bezpłatną wycenę. Bez zobowiązań, bez pośpiechu. Każda współpraca zaczyna się od rozmowy.
          </p>

          <div class="kontakt__actions">
            <a href="mailto:kontakt@henostudio.com?subject=Zapytanie o projekt wnętrza" class="kontakt__action-card">
              <div class="kontakt__action-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <span class="kontakt__action-label">Email</span>
                <span class="kontakt__action-value">kontakt@henostudio.com</span>
              </div>
            </a>

            <a href="tel:+48607564257" class="kontakt__action-card">
              <div class="kontakt__action-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <span class="kontakt__action-label">Telefon</span>
                <span class="kontakt__action-value">+48 607 564 257</span>
              </div>
            </a>
          </div>
        </div>

        <div class="kontakt__info reveal" style="transition-delay: 150ms">
          <div class="kontakt__info-card">
            <h2 class="kontakt__info-title">Dane firmy</h2>
            <dl class="kontakt__details">
              <div>
                <dt>Studio</dt>
                <dd>Heno Studio</dd>
              </div>
              <div>
                <dt>Właścicielka</dt>
                <dd>Patrycja Zarzycka-Paluch</dd>
              </div>
              <div>
                <dt>Lokalizacja</dt>
                <dd>Wrocław</dd>
              </div>
              <div>
                <dt>NIP</dt>
                <dd>8943150102</dd>
              </div>
            </dl>

            <div class="kontakt__social">
              <h3>Social media</h3>
              <div class="kontakt__social-links">
                <a href="https://facebook.com/heno.studio" target="_blank" rel="noopener noreferrer" class="kontakt__social-link">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                  Facebook
                </a>
                <a href="https://instagram.com/heno.studio" target="_blank" rel="noopener noreferrer" class="kontakt__social-link">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  Instagram
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Map height="350px" />
  <Footer slot="footer" />
</BaseLayout>

<style>
  .kontakt-page {
    padding-top: calc(var(--header-height) + var(--space-4xl));
    padding-bottom: var(--space-4xl);
    min-height: 80vh;
  }

  .kontakt__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .kontakt__title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-lg);
    line-height: 1.1;
  }

  .kontakt__desc {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: var(--space-2xl);
  }

  .kontakt__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .kontakt__action-card {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    border: 1px solid var(--color-border);
    background: var(--color-white);
    transition: all var(--transition-base);
    text-decoration: none;
    min-height: 48px;
  }

  .kontakt__action-card:hover {
    border-color: var(--color-secondary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .kontakt__action-icon {
    color: var(--color-secondary-dark);
    flex-shrink: 0;
  }

  .kontakt__action-label {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  .kontakt__action-value {
    display: block;
    font-size: var(--text-lg);
    color: var(--color-primary);
    font-weight: 500;
  }

  .kontakt__info-card {
    background: var(--color-bg-warm);
    padding: var(--space-2xl);
  }

  .kontakt__info-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-lg);
  }

  .kontakt__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .kontakt__details div {
    display: flex;
    justify-content: space-between;
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border-light);
  }

  .kontakt__details dt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .kontakt__details dd {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 500;
  }

  .kontakt__social h3 {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .kontakt__social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .kontakt__social-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-light);
    padding: var(--space-sm) 0;
    min-height: 44px;
  }

  .kontakt__social-link:hover {
    color: var(--color-secondary-dark);
  }

  @media (min-width: 768px) {
    .kontakt__grid {
      grid-template-columns: 3fr 2fr;
    }

    .kontakt__actions {
      max-width: 440px;
    }
  }
</style>
