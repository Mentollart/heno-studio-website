---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Portfolio | Projekty wnętrz Wrocław — Heno Studio"
  description="Zobacz nasze realizacje: projekty wnętrz mieszkań i domów we Wrocławiu i okolicach. Mieszkania od 52m² do 84m², domy w Trzebnicy, Lubinie i pod Wrocławiem."
>
  <Header slot="header" />

  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Ścieżka nawigacji">
        <a href="/">Strona główna</a>
        <span>/</span>
        <span aria-current="page">Portfolio</span>
      </nav>
      <h1 class="page-header__title">Portfolio</h1>
      <p class="page-header__desc">
        Każdy projekt to unikalna historia. Zobacz, jak zamieniamy wizje naszych klientów w&nbsp;funkcjonalne, piękne wnętrza — od kompaktowych mieszkań po przestronne domy.
      </p>
    </div>
  </section>

  <PortfolioGrid limit={9} showMore={false} />

  <ContactCTA variant="dark" />
  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header {
    padding-top: calc(var(--header-height) + var(--space-3xl));
    padding-bottom: var(--space-2xl);
    background: var(--color-bg-warm);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
  }

  .breadcrumb a:hover {
    color: var(--color-secondary-dark);
  }

  .page-header__title {
    margin-bottom: var(--space-md);
  }

  .page-header__desc {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    max-width: 640px;
  }
</style>
