---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/portfolio/*.{png,jpg,jpeg,webp}',
  { eager: true }
);

const imagePath = Object.keys(images).find((path) =>
  path.includes(project.imageSrc)
);
const image = imagePath ? images[imagePath].default : null;

// Find adjacent projects for navigation
const currentIndex = projects.findIndex((p) => p.slug === project.slug);
const prevProject = currentIndex > 0 ? projects[currentIndex - 1] : null;
const nextProject = currentIndex < projects.length - 1 ? projects[currentIndex + 1] : null;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": project.name,
  "description": project.description,
  "creator": {
    "@type": "ProfessionalService",
    "name": "Heno Studio",
    "url": "https://henostudio.pl"
  },
  "locationCreated": {
    "@type": "Place",
    "name": project.location
  },
  "image": `https://henostudio.pl/portfolio/${project.slug}`,
  "url": `https://henostudio.pl/portfolio/${project.slug}`
};

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Strona główna", "item": "https://henostudio.pl/" },
    { "@type": "ListItem", "position": 2, "name": "Portfolio", "item": "https://henostudio.pl/portfolio" },
    { "@type": "ListItem", "position": 3, "name": project.name, "item": `https://henostudio.pl/portfolio/${project.slug}` }
  ]
};
---

<BaseLayout
  title={project.seoTitle}
  description={project.seoDescription}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />
  </Fragment>

  <Header slot="header" />

  <article class="project-page">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Ścieżka nawigacji">
        <a href="/">Strona główna</a>
        <span>/</span>
        <a href="/portfolio">Portfolio</a>
        <span>/</span>
        <span aria-current="page">{project.name}</span>
      </nav>

      <!-- Hero Image -->
      <div class="project__hero reveal">
        {image && (
          <Image
            src={image}
            alt={project.imageAlt}
            widths={[640, 960, 1280, 1920]}
            sizes="100vw"
            format="webp"
            quality={80}
            loading="eager"
            class="project__hero-img"
          />
        )}
      </div>

      <!-- Project Info -->
      <div class="project__info-grid">
        <div class="project__content reveal">
          <h1 class="project__title">{project.name}</h1>
          <p class="project__description">{project.description}</p>

          <a
            href={`mailto:kontakt@henostudio.com?subject=Zapytanie - Projekt podobny do: ${project.name}`}
            class="btn btn--primary"
          >
            Chcę podobny projekt
          </a>
        </div>

        <aside class="project__meta reveal" style="transition-delay: 150ms">
          <div class="project__meta-card">
            <dl>
              <div>
                <dt>Lokalizacja</dt>
                <dd>{project.location}</dd>
              </div>
              {project.size && (
                <div>
                  <dt>Powierzchnia</dt>
                  <dd>{project.size}</dd>
                </div>
              )}
              <div>
                <dt>Typ</dt>
                <dd>{project.type === 'mieszkanie' ? 'Mieszkanie' : 'Dom'}</dd>
              </div>
            </dl>

            <div class="project__scope">
              <h2>Zakres prac</h2>
              <ul>
                {project.scope.map((item) => (
                  <li>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      </div>

      <!-- Project Navigation -->
      <nav class="project__nav" aria-label="Nawigacja między projektami">
        {prevProject ? (
          <a href={`/portfolio/${prevProject.slug}`} class="project__nav-link project__nav-link--prev">
            <span class="project__nav-label">Poprzedni</span>
            <span class="project__nav-name">{prevProject.name}</span>
          </a>
        ) : <div />}
        {nextProject ? (
          <a href={`/portfolio/${nextProject.slug}`} class="project__nav-link project__nav-link--next">
            <span class="project__nav-label">Następny</span>
            <span class="project__nav-name">{nextProject.name}</span>
          </a>
        ) : <div />}
      </nav>
    </div>
  </article>

  <ContactCTA variant="dark" />
  <Footer slot="footer" />
</BaseLayout>

<style>
  .project-page {
    padding-top: calc(var(--header-height) + var(--space-xl));
    padding-bottom: var(--space-3xl);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .breadcrumb a { color: var(--color-text-muted); }
  .breadcrumb a:hover { color: var(--color-secondary-dark); }

  .project__hero {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    margin-bottom: var(--space-3xl);
    background: var(--color-bg-warm);
  }

  .project__hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project__info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-3xl);
  }

  .project__title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-xl);
  }

  .project__description {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text-light);
    margin-bottom: var(--space-2xl);
  }

  .project__meta-card {
    background: var(--color-bg-warm);
    padding: var(--space-2xl);
  }

  .project__meta-card dl {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .project__meta-card dl div {
    display: flex;
    justify-content: space-between;
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border-light);
  }

  .project__meta-card dt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .project__meta-card dd {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 500;
  }

  .project__scope h2 {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .project__scope ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .project__scope li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .project__scope svg {
    color: var(--color-secondary);
    flex-shrink: 0;
  }

  .project__nav {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid var(--color-border-light);
    padding-top: var(--space-xl);
  }

  .project__nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    max-width: 45%;
  }

  .project__nav-link--next {
    text-align: right;
    margin-left: auto;
  }

  .project__nav-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .project__nav-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .project__nav-link:hover .project__nav-name {
    color: var(--color-secondary-dark);
  }

  @media (min-width: 768px) {
    .project__info-grid {
      grid-template-columns: 3fr 2fr;
    }
  }
</style>
