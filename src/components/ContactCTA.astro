---
interface Props {
  variant?: 'default' | 'dark';
}

const { variant = 'default' } = Astro.props;
const isDark = variant === 'dark';
---

<section class:list={['cta-section', 'section', { 'section--dark': isDark }]}>
  <div class="container text-center">
    <div class="cta-section__content reveal">
      <p class="section-label" style={isDark ? 'color: var(--color-secondary-light)' : ''}>Kontakt</p>
      <h2 class="section-title" style={isDark ? 'color: var(--color-white)' : ''}>
        Gotowy na zmianę<br />swojego wnętrza?
      </h2>
      <p class="cta-section__desc" style={isDark ? 'color: rgba(255,255,255,0.7)' : ''}>
        Napisz, czego potrzebujesz — bezpłatna wycena projektu mieszkania we Wrocławiu czeka na Ciebie. Bez zobowiązań.
      </p>
      <div class="cta-section__buttons">
        <a href="mailto:kontakt@henostudio.com?subject=Zapytanie o projekt wnętrza" class:list={['btn', 'btn--lg', isDark ? 'btn--white' : 'btn--primary']}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          kontakt@henostudio.com
        </a>
        <a href="tel:+48607564257" class:list={['btn', 'btn--lg', isDark ? 'btn--secondary cta-section__phone-dark' : 'btn--secondary']}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          +48 607 564 257
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section__content {
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-section__desc {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    margin-bottom: var(--space-2xl);
  }

  .cta-section__buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: center;
  }

  .cta-section__phone-dark {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .cta-section__phone-dark:hover {
    background: var(--color-white);
    color: var(--color-primary);
  }

  @media (min-width: 640px) {
    .cta-section__buttons {
      flex-direction: row;
      justify-content: center;
    }
  }
</style>
