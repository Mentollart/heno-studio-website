---
const testimonials = [
  {
    name: 'Monika U.',
    rating: 5,
    timeAgo: '2 lata temu',
    text: 'Długo szukałam studia, które sprosta moim wymaganiom. Heno Studio spełniło moje oczekiwania. Profesjonalna obsługa na całym etapie projektowania.',
    source: 'Google',
  },
  {
    name: 'Barbara',
    rating: 5,
    timeAgo: '2 lata temu',
    text: 'Współpraca z Heno Studio to wielka przyjemność. Pani Patrycja ma duże doświadczenie i szeroką wiedzę w dziedzinie projektowania wnętrz. Jesteśmy bardzo zadowoleni.',
    source: 'Google',
  },
  {
    name: 'Jan Demczak',
    rating: 5,
    timeAgo: '5 lat temu',
    text: 'Jestem bardzo zadowolony ze współpracy z Panią Patrycją. Projekt przewyższył moje oczekiwania, a nie należę do najłatwiejszych klientów.',
    source: 'Google',
  },
  {
    name: 'Paweł Szulc',
    rating: 5,
    timeAgo: '4 lata temu',
    text: 'Kiedyś żyłem w smutnym, pozbawionym stylu mieszkaniu. Teraz najchętniej w ogóle nie wychodziłbym na zewnątrz! Heno Studio to najlepsze, co mi się przytrafiło.',
    source: 'Google',
  },
  {
    name: 'Adrianna Michalik',
    rating: 5,
    timeAgo: '2 lata temu',
    text: 'Pełen profesjonalizm, wszystko wykonane na czas, piękny projekt!',
    source: 'Google',
  },
];

const stars = '★★★★★';
---

<section class="testimonials section" id="opinie">
  <div class="container">
    <div class="testimonials__header text-center reveal">
      <p class="section-label">Opinie klientów</p>
      <h2 class="section-title">Co mówią nasi klienci</h2>
      <div class="testimonials__google-badge">
        <svg class="testimonials__google-icon" width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        <span class="testimonials__google-rating">5.0</span>
        <span class="testimonials__google-stars">{stars}</span>
        <span class="testimonials__google-count">8 opinii w Google</span>
      </div>
    </div>

    <div class="testimonials__grid">
      {testimonials.map((t, i) => (
        <article class="testimonial reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class="testimonial__stars">{stars}</div>
          <blockquote class="testimonial__text">
            <p>"{t.text}"</p>
          </blockquote>
          <div class="testimonial__author">
            <div class="testimonial__avatar">{t.name.charAt(0)}</div>
            <div>
              <cite class="testimonial__name">{t.name}</cite>
              <span class="testimonial__meta">{t.source} · {t.timeAgo}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="testimonials__cta text-center reveal">
      <a href="https://www.google.com/search?kgmid=/g/11q_7s__c4&q=Heno+Studio&shndl=30&source=sh/x/loc/uni/m1/1&kgs=9648512dcbfa221b" target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
        Zobacz wszystkie opinie w Google
      </a>
    </div>
  </div>
</section>

<style>
  .testimonials__header {
    margin-bottom: var(--space-3xl);
  }

  .testimonials__google-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    padding: var(--space-sm) var(--space-lg);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    font-size: var(--text-sm);
  }

  .testimonials__google-icon {
    flex-shrink: 0;
  }

  .testimonials__google-rating {
    font-weight: 600;
    color: var(--color-primary);
  }

  .testimonials__google-stars {
    color: #FBBC05;
    letter-spacing: 1px;
  }

  .testimonials__google-count {
    color: var(--color-text-muted);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .testimonial {
    background: var(--color-white);
    border: 1px solid var(--color-border-light);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: all var(--transition-base);
  }

  .testimonial:hover {
    border-color: var(--color-secondary-light);
    box-shadow: var(--shadow-sm);
  }

  .testimonial__stars {
    color: #FBBC05;
    font-size: var(--text-lg);
    letter-spacing: 2px;
  }

  .testimonial__text {
    margin: 0;
    flex-grow: 1;
  }

  .testimonial__text p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-light);
    font-style: italic;
    margin: 0;
  }

  .testimonial__author {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border-light);
  }

  .testimonial__avatar {
    width: 40px;
    height: 40px;
    background: var(--color-bg-warm);
    color: var(--color-secondary-dark);
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .testimonial__name {
    display: block;
    font-style: normal;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
  }

  .testimonial__meta {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    /* Last 2 cards centered when 5 items in 3-col grid */
    .testimonial:nth-child(4) {
      grid-column: 1 / 2;
    }

    .testimonial:nth-child(5) {
      grid-column: 2 / 3;
    }
  }
</style>
