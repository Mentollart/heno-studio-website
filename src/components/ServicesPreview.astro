---
const services = [
  {
    name: 'Projekt koncepcyjny',
    price: 'od 150 zł/m²',
    desc: 'Wizualizacje 3D, moodboard i układ funkcjonalny — idealna baza do samodzielnej realizacji.',
    features: ['Inwentaryzacja', 'Moodboard/styl', 'Wizualizacje 3D', 'Układ funkcjonalny'],
  },
  {
    name: 'Projekt kompleksowy',
    price: 'od 210 zł/m²',
    desc: 'Pełna dokumentacja techniczna ze szczegółową listą zakupową i wizytami na budowie.',
    features: ['Rysunki techniczne', 'Lista zakupowa z linkami', '3 wizyty na budowie', 'Wszystko z projektu koncepcyjnego'],
    popular: true,
  },
  {
    name: 'Projekt z nadzorem',
    price: 'od 320 zł/m²',
    desc: 'Kompleksowa opieka od projektu do realizacji — koordynacja wykonawców i dostaw.',
    features: ['Zaufana ekipa wykończeniowa', 'Wizyty wg potrzeb', 'Koordynacja dostaw', 'Pomoc w zakupach'],
  },
  {
    name: 'Konsultacje',
    price: 'od 500 zł',
    desc: 'Jednorazowa porada na żywo lub online — odpowiedzi na konkretne pytania projektowe.',
    features: ['Na żywo lub online', 'Przygotowanie materiałów', 'Podsumowanie pisemne'],
  },
];
---

<section class="services section" id="oferta">
  <div class="container">
    <div class="services__header text-center reveal">
      <p class="section-label">Oferta</p>
      <h2 class="section-title">Jak mogę Ci pomóc?</h2>
      <p class="section-subtitle mx-auto">
        Dopasowuję zakres współpracy do Twoich potrzeb i&nbsp;budżetu — od szybkiej konsultacji po pełen nadzór nad realizacją.
      </p>
    </div>

    <div class="services__grid">
      {services.map((service, i) => (
        <div class:list={['services__card', 'reveal', { 'services__card--popular': service.popular }]} style={`transition-delay: ${i * 100}ms`}>
          {service.popular && <span class="services__badge">Najpopularniejszy</span>}
          <h3 class="services__name">{service.name}</h3>
          <p class="services__price">{service.price}</p>
          <p class="services__desc">{service.desc}</p>
          <ul class="services__features">
            {service.features.map((f) => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="mailto:kontakt@henostudio.com?subject=Zapytanie - {service.name}" class:list={['btn', 'services__btn', service.popular ? 'btn--primary' : 'btn--secondary']}>
            Zapytaj o wycenę
          </a>
        </div>
      ))}
    </div>

    <div class="services__more text-center reveal">
      <a href="/oferta" class="btn btn--secondary">
        Zobacz pełną ofertę
      </a>
    </div>
  </div>
</section>

<style>
  .services__header {
    margin-bottom: var(--space-3xl);
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .services__card {
    position: relative;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: var(--space-2xl) var(--space-xl);
    display: flex;
    flex-direction: column;
    transition: all var(--transition-base);
  }

  .services__card:hover {
    border-color: var(--color-secondary-light);
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .services__card--popular {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
  }

  .services__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--space-xs) var(--space-md);
    white-space: nowrap;
  }

  .services__name {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }

  .services__price {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-secondary-dark);
    margin-bottom: var(--space-md);
  }

  .services__desc {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-lg);
  }

  .services__features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
    flex-grow: 1;
  }

  .services__features li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .services__features svg {
    color: var(--color-secondary);
    flex-shrink: 0;
  }

  .services__btn {
    width: 100%;
    margin-top: auto;
  }

  @media (min-width: 768px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
