---
interface Props {
  height?: string;
}

const { height = '400px' } = Astro.props;
---

<section class="map-section">
  <div class="map-section__header container reveal">
    <p class="section-label">Lokalizacja</p>
    <h2 class="section-title">Wrocław i okolice</h2>
    <p class="map-section__desc">Realizujemy projekty we Wrocławiu, okolicach oraz zdalnie w całej Polsce.</p>
  </div>
  <div class="map-section__embed" style={`height: ${height}`}>
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2503.92564820319!2d16.96031217796239!3d51.128279471729506!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x470feb63fe0426d7%3A0x9fbe14aec8609b4d!2sHeno%20Studio!5e0!3m2!1spl!2spl!4v1775564342667!5m2!1spl!2spl"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Heno Studio - Wrocław"
    ></iframe>
  </div>
</section>

<style>
  .map-section__header {
    padding-top: var(--space-section);
    padding-bottom: var(--space-2xl);
  }

  .map-section__desc {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    max-width: 480px;
  }

  .map-section__embed {
    width: 100%;
    background: var(--color-bg-warm);
  }

  .map-section__embed iframe {
    display: block;
  }
</style>
