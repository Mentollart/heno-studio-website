---
interface Props {
  height?: string;
}

const { height = '400px' } = Astro.props;
---

<section class="map-section">
  <div class="map-section__header container reveal">
    <p class="section-label">Lokalizacja</p>
    <h2 class="section-title">Wrocław i okolice</h2>
    <p class="map-section__desc">Realizujemy projekty we Wrocławiu, okolicach oraz zdalnie w całej Polsce.</p>
  </div>
  <div class="map-section__embed" style={`height: ${height}`}>
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d80338.0994786498!2d16.937!3d51.1079!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x470fe9c2d4b58abf%3A0xb70956aec205e0f5!2sWroc%C5%82aw!5e0!3m2!1spl!2spl!4v1700000000000!5m2!1spl!2spl"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Heno Studio - Wrocław"
    ></iframe>
  </div>
</section>

<style>
  .map-section__header {
    padding-top: var(--space-section);
    padding-bottom: var(--space-2xl);
  }

  .map-section__desc {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    max-width: 480px;
  }

  .map-section__embed {
    width: 100%;
    background: var(--color-bg-warm);
  }

  .map-section__embed iframe {
    display: block;
  }
</style>
